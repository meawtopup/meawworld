# ในโฟลเดอร์ meawworld/
cat > .gitignore << 'EOF'
# ==========================================
# MeawWorld - Files to ignore
# ==========================================

# 🔒 Local files (private)
local/
*.secret
*.key
*-credentials.txt

# 🔒 Host scripts (private)
scripts/host/*.user.js
scripts/host/meawworld-host.*

# 🔒 Configuration files
.env
.env.local
config.local.js
host-config.json

# Dependencies
node_modules/
package-lock.json

# Supabase local
supabase/.temp/
supabase/.branches/

# OS files
.DS_Store
Thumbs.db
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env.local
.env.production
EOF
